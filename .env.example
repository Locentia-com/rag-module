# =============================================================================
# Local-first: Diese Defaults laufen komplett OHNE externe API-Keys.
# Externe Dienste sind optionale Andockstellen über die *_BACKEND-Schalter.
# =============================================================================

# --- Vektordatenbank ---------------------------------------------------------
RAG_QDRANT_URL=http://localhost:6333
# RAG_QDRANT_API_KEY=
RAG_COLLECTION_NAME=rag_chunks

# --- Dense-Embeddings ----------------------------------------------------------
# "fastembed" (lokal/ONNX, Default) | "bge_m3" (lokal/Torch) | "cohere" (API-Key)
RAG_DENSE_BACKEND=fastembed
RAG_FASTEMBED_DENSE_MODEL=intfloat/multilingual-e5-large
# Andockstelle Cohere (nur bei RAG_DENSE_BACKEND=cohere nötig):
# RAG_COHERE_API_KEY=
# RAG_COHERE_EMBED_MODEL=embed-multilingual-v3.0

# --- Sparse-Embeddings (lexikalisch/BM25) ---------------------------------------
# "fastembed_bm25" (lokal, Default) | "bge_m3"
RAG_SPARSE_BACKEND=fastembed_bm25

# --- Re-Ranking ------------------------------------------------------------------
# "fastembed" (lokal/ONNX, Default) | "bge" (lokal/Torch, beste Qualität)
# | "cohere" (API-Key) | "none"
RAG_RERANK_BACKEND=fastembed
RAG_FASTEMBED_RERANK_MODEL=BAAI/bge-reranker-base
# RAG_BGE_RERANK_MODEL=BAAI/bge-reranker-v2-m3
# RAG_COHERE_RERANK_MODEL=rerank-v3.5
# true: Bei Reranker-Ausfall RRF-Reihenfolge liefern statt Fehler zu werfen
RAG_RERANK_FAIL_OPEN=false

# --- Query Expansion (leichtes LLM) -----------------------------------------------
# "none" (Default) | "ollama" (lokal, kein Key) | "anthropic" (API-Key)
RAG_EXPANSION_BACKEND=none
# RAG_OLLAMA_URL=http://localhost:11434
# RAG_OLLAMA_MODEL=llama3.2
# RAG_ANTHROPIC_API_KEY=
# RAG_ANTHROPIC_EXPANSION_MODEL=claude-haiku-4-5-20251001
RAG_NUM_QUERY_EXPANSIONS=3

# --- Chunking / Retrieval-Tuning ----------------------------------------------------
RAG_CHUNK_MAX_TOKENS=480
RAG_CHUNK_OVERLAP_TOKENS=64
RAG_PARENT_MAX_TOKENS=1800
RAG_CANDIDATE_POOL_SIZE=50
RAG_RRF_K=60
